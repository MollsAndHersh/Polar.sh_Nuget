{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PolarSharp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "PolarSharp": {
    "Webhooks": {
      "Secret": "whsec_placeholder_replace_via_user_secrets",
      "Path": "/hooks/polar",
      "RequireHttps": false,
      "ToleranceSeconds": 300,
      "MaxPayloadBytes": 1048576,
      "EnableRateLimiting": false,
      "WarnOnUnhandledEventTypes": true,
      "FailOnMissingHandlers": false,
      "GracefulDrainTimeoutSeconds": 30
    }
  }
}
