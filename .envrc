# direnv configuration for Polar.sh_Nuget
#
# Loads developer-local environment variables from `.env` whenever a shell enters
# this repo (or any subdirectory). Requires direnv (`brew install direnv` plus
# `eval "$(direnv hook zsh)"` or equivalent in your shell rc).
#
# After cloning the repo for the first time:
#   1. Copy `.env.example` to `.env`
#   2. Fill in values (GH_TOKEN, ANTHROPIC_API_KEY, etc.)
#   3. Run `direnv allow .` from this directory
#
# `.env` is gitignored — secrets stay on your machine.

dotenv_if_exists .env
