# Polar.sh_Nuget — local environment variables template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is committed so new contributors know what variables to set.
# Loaded automatically by direnv via `.envrc` once you run `direnv allow .`.

# GitHub Personal Access Token used by `gh` CLI, REST API calls (curl), and
# CI test scripts that exercise the GitHub Packages publish path locally.
# Generate at https://github.com/settings/tokens or extract from `gh auth token`.
# Required scopes: repo, read:org, gist (matches what `gh auth login` requests).
GH_TOKEN=

# Same value as GH_TOKEN — some tools read GITHUB_TOKEN instead.
# Set both so tooling works regardless of which name it expects.
GITHUB_TOKEN=

# Anthropic API key for Claude-based commit message generation via
# `agentic-master commit --ai --provider anthropic`, plus any host-side
# translation provider tests that target Anthropic. Optional.
ANTHROPIC_API_KEY=
