<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsLibrary>true</IsLibrary>
    <PackageId>PolarSharp.EcommerceStorefronts.MAUI</PackageId>
    <Version>1.0.0</Version>
    <Authors>Molls and Hersh, LLC</Authors>
    <Description>MAUI Blazor Hybrid + native XAML wrappers for the Blazor storefront components.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>polar;ecommerce;storefronts;maui;saas</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>PolarSharp.EcommerceStorefronts.MAUI</RootNamespace>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <!-- Scaffold-only single-target net10.0 for now; MAUI target frameworks (net10.0-android, net10.0-ios, etc.) defer to Phase 29.x when MAUI Blazor Hybrid wrappers are authored. -->
    <ProjectReference Include="..\PolarSharp.EcommerceStorefronts.Blazor\PolarSharp.EcommerceStorefronts.Blazor.csproj" />
  </ItemGroup>

</Project>
