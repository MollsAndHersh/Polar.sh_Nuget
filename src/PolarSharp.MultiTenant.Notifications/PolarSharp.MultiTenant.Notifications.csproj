<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsLibrary>true</IsLibrary>
    <PackageId>PolarSharp.MultiTenant.Notifications</PackageId>
    <Version>1.0.0</Version>
    <Authors>Molls and Hersh, LLC</Authors>
    <Description>Optional tenant lifecycle notification dispatcher (email + SMS + webhook) for PolarSharp.MultiTenant. Subscribes to TenantStatusChangedNotification and sends templated messages to the tenant's site manager.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>polar;multi-tenant;notifications;email;sms;webhook;sendgrid;twilio;sdk;aot</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>PolarSharp.MultiTenant.Notifications</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PolarSharp.MultiTenant.Notifications.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PolarSharp.MultiTenant\PolarSharp.MultiTenant.csproj" />
    <PackageReference Include="MediatR" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
  </ItemGroup>

</Project>
