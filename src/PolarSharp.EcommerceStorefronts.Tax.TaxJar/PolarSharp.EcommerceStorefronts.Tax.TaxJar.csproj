<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsLibrary>true</IsLibrary>
    <PackageId>PolarSharp.EcommerceStorefronts.Tax.TaxJar</PackageId>
    <Version>1.0.0</Version>
    <Authors>Molls and Hersh, LLC</Authors>
    <Description>TaxJar provider for IStorefrontTaxProvider — US sales tax + VAT + GST.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>polar;ecommerce;storefronts;tax;taxjar;saas</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>PolarSharp.EcommerceStorefronts.Tax.TaxJar</RootNamespace>
    <!-- TaxJar 4.0.0 transitively depends on RestSharp 108.0.3 which has a known moderate severity advisory (GHSA-4rr6-2v9v-wcpc). Suppress audit warnings until TaxJar ships an updated SDK. -->
    <NoWarn>CS1591;NU1902;NU1903</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PolarSharp.EcommerceStorefronts.Tax\PolarSharp.EcommerceStorefronts.Tax.csproj" />
    <PackageReference Include="TaxJar" />
  </ItemGroup>

</Project>
