<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsLibrary>true</IsLibrary>
    <PackageId>PolarSharp.NaturalLanguageQuery.HotChocolate</PackageId>
    <Version>1.0.0</Version>
    <Authors>Molls and Hersh, LLC</Authors>
    <Description>Hot Chocolate target for natural-language → GraphQL query generation.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>polar;nlquery;graphql;hotchocolate;ai;llm;saas</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>PolarSharp.NaturalLanguageQuery.HotChocolate</RootNamespace>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PolarSharp.NaturalLanguageQuery\PolarSharp.NaturalLanguageQuery.csproj" />
    <ProjectReference Include="..\PolarSharp.Reporting.GraphQL\PolarSharp.Reporting.GraphQL.csproj" />
    <ProjectReference Include="..\PolarSharp.EcommerceStoreManagement.GraphQL\PolarSharp.EcommerceStoreManagement.GraphQL.csproj" />
    <PackageReference Include="HotChocolate.Execution" />
  </ItemGroup>

</Project>
