<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsLibrary>true</IsLibrary>
    <PackageId>PolarSharp.Webhooks</PackageId>
    <Version>1.1.0</Version>
    <Authors>Molls and Hersh, LLC</Authors>
    <Description>Webhook integration package for PolarSharp — HMAC verification, typed event handlers, toast notifications, and reconciliation for Polar.sh.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>polar;webhooks;payments;sdk;aot</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>PolarSharp.Webhooks</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PolarSharp.Webhooks.Tests" />
    <InternalsVisibleTo Include="PolarSharp.IntegrationTests" />
    <InternalsVisibleTo Include="PolarSharp.Benchmarks" />
  </ItemGroup>

  <!-- .resx files are auto-included by the SDK as EmbeddedResource items.
       The Update attribute configures (not duplicates) the main file for the code generator. -->
  <ItemGroup>
    <EmbeddedResource Update="Localization\Resources\PolarWebhookMessages.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>PolarWebhookMessages.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

</Project>
