<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsLibrary>true</IsLibrary>
    <PackageId>PolarSharp.Reporting</PackageId>
    <Version>1.0.0</Version>
    <Authors>Molls and Hersh, LLC</Authors>
    <Description>Per-tenant reporting over Polar.sh transactions, subscriptions, orders, customers, entitlements, and webhook errors. JSON-first API. Optional time-series snapshot service. Install one of the .EntityFrameworkCore.{SqlServer,Sqlite,PostgreSQL} providers to enable local snapshot caching.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mollsandhersh/Polar.sh_Nuget</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>polar;reporting;analytics;saas;sdk;aot</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RootNamespace>PolarSharp.Reporting</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PolarSharp\PolarSharp.csproj" />
    <ProjectReference Include="..\PolarSharp.BaseEntities\PolarSharp.BaseEntities.csproj" />
    <ProjectReference Include="..\PolarSharp.MultiTenant\PolarSharp.MultiTenant.csproj" />
    <ProjectReference Include="..\PolarSharp.MultiTenant.EntityFrameworkCore\PolarSharp.MultiTenant.EntityFrameworkCore.csproj" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PolarSharp.Reporting.EntityFrameworkCore" />
    <InternalsVisibleTo Include="PolarSharp.Reporting.EntityFrameworkCore.SqlServer" />
    <InternalsVisibleTo Include="PolarSharp.Reporting.EntityFrameworkCore.Sqlite" />
    <InternalsVisibleTo Include="PolarSharp.Reporting.EntityFrameworkCore.PostgreSQL" />
    <InternalsVisibleTo Include="PolarSharp.Reporting.Tests" />
  </ItemGroup>

</Project>
