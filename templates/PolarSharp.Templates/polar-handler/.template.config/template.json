{
  "$schema": "http://json.schemastore.org/template",
  "author": "Mark Chipman",
  "classifications": [ "PolarSharp", "Webhook", "Handler" ],
  "identity": "PolarSharp.WebhookHandler.1.0",
  "name": "Polar.sh Webhook Handler",
  "shortName": "polar-handler",
  "description": "Scaffolds a strongly-typed IPolarWebhookHandler<TEvent> implementation for a Polar.sh webhook event.",
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "sourceName": "EventHandler",
  "preferNameDirectory": false,
  "symbols": {
    "Event": {
      "type": "parameter",
      "displayName": "Polar event type",
      "description": "The Polar webhook event type to handle.",
      "datatype": "choice",
      "defaultValue": "OrderCreatedEvent",
      "replaces": "OrderCreatedEvent",
      "choices": [
        { "choice": "OrderCreatedEvent",           "description": "order.created — new order placed" },
        { "choice": "OrderUpdatedEvent",           "description": "order.updated — order details changed" },
        { "choice": "OrderPaidEvent",              "description": "order.paid — payment confirmed" },
        { "choice": "OrderRefundedEvent",          "description": "order.refunded — order refunded" },
        { "choice": "SubscriptionCreatedEvent",    "description": "subscription.created — subscription started" },
        { "choice": "SubscriptionActiveEvent",     "description": "subscription.active — subscription became active" },
        { "choice": "SubscriptionUpdatedEvent",    "description": "subscription.updated — subscription changed" },
        { "choice": "SubscriptionCanceledEvent",   "description": "subscription.canceled — subscription canceled" },
        { "choice": "SubscriptionUncanceledEvent", "description": "subscription.uncanceled — cancellation reversed" },
        { "choice": "SubscriptionPastDueEvent",    "description": "subscription.past_due — payment failed" },
        { "choice": "SubscriptionRevokedEvent",    "description": "subscription.revoked — subscription revoked" },
        { "choice": "CheckoutCreatedEvent",        "description": "checkout.created — checkout session opened" },
        { "choice": "CheckoutUpdatedEvent",        "description": "checkout.updated — checkout session updated" },
        { "choice": "CheckoutExpiredEvent",        "description": "checkout.expired — checkout session expired" },
        { "choice": "CustomerCreatedEvent",        "description": "customer.created — new customer registered" },
        { "choice": "CustomerUpdatedEvent",        "description": "customer.updated — customer profile changed" },
        { "choice": "CustomerStateChangedEvent",   "description": "customer.state_changed — customer state transition" },
        { "choice": "CustomerDeletedEvent",        "description": "customer.deleted — customer account deleted" },
        { "choice": "ProductCreatedEvent",         "description": "product.created — new product created" },
        { "choice": "ProductUpdatedEvent",         "description": "product.updated — product details changed" },
        { "choice": "BenefitCreatedEvent",         "description": "benefit.created — new benefit created" },
        { "choice": "BenefitUpdatedEvent",         "description": "benefit.updated — benefit changed" },
        { "choice": "BenefitGrantCreatedEvent",    "description": "benefit_grant.created — benefit granted to customer" },
        { "choice": "BenefitGrantUpdatedEvent",    "description": "benefit_grant.updated — grant updated" },
        { "choice": "BenefitGrantCycledEvent",     "description": "benefit_grant.cycled — grant renewed for billing cycle" },
        { "choice": "BenefitGrantRevokedEvent",    "description": "benefit_grant.revoked — benefit revoked from customer" },
        { "choice": "RefundCreatedEvent",          "description": "refund.created — refund initiated" },
        { "choice": "RefundUpdatedEvent",          "description": "refund.updated — refund status changed" }
      ]
    },
    "IsOrderCreatedEvent":           { "type": "computed", "value": "(Event == \"OrderCreatedEvent\")" },
    "IsOrderUpdatedEvent":           { "type": "computed", "value": "(Event == \"OrderUpdatedEvent\")" },
    "IsOrderPaidEvent":              { "type": "computed", "value": "(Event == \"OrderPaidEvent\")" },
    "IsOrderRefundedEvent":          { "type": "computed", "value": "(Event == \"OrderRefundedEvent\")" },
    "IsSubscriptionCreatedEvent":    { "type": "computed", "value": "(Event == \"SubscriptionCreatedEvent\")" },
    "IsSubscriptionActiveEvent":     { "type": "computed", "value": "(Event == \"SubscriptionActiveEvent\")" },
    "IsSubscriptionUpdatedEvent":    { "type": "computed", "value": "(Event == \"SubscriptionUpdatedEvent\")" },
    "IsSubscriptionCanceledEvent":   { "type": "computed", "value": "(Event == \"SubscriptionCanceledEvent\")" },
    "IsSubscriptionUncanceledEvent": { "type": "computed", "value": "(Event == \"SubscriptionUncanceledEvent\")" },
    "IsSubscriptionPastDueEvent":    { "type": "computed", "value": "(Event == \"SubscriptionPastDueEvent\")" },
    "IsSubscriptionRevokedEvent":    { "type": "computed", "value": "(Event == \"SubscriptionRevokedEvent\")" },
    "IsCheckoutCreatedEvent":        { "type": "computed", "value": "(Event == \"CheckoutCreatedEvent\")" },
    "IsCheckoutUpdatedEvent":        { "type": "computed", "value": "(Event == \"CheckoutUpdatedEvent\")" },
    "IsCheckoutExpiredEvent":        { "type": "computed", "value": "(Event == \"CheckoutExpiredEvent\")" },
    "IsCustomerCreatedEvent":        { "type": "computed", "value": "(Event == \"CustomerCreatedEvent\")" },
    "IsCustomerUpdatedEvent":        { "type": "computed", "value": "(Event == \"CustomerUpdatedEvent\")" },
    "IsCustomerStateChangedEvent":   { "type": "computed", "value": "(Event == \"CustomerStateChangedEvent\")" },
    "IsCustomerDeletedEvent":        { "type": "computed", "value": "(Event == \"CustomerDeletedEvent\")" },
    "IsProductCreatedEvent":         { "type": "computed", "value": "(Event == \"ProductCreatedEvent\")" },
    "IsProductUpdatedEvent":         { "type": "computed", "value": "(Event == \"ProductUpdatedEvent\")" },
    "IsBenefitCreatedEvent":         { "type": "computed", "value": "(Event == \"BenefitCreatedEvent\")" },
    "IsBenefitUpdatedEvent":         { "type": "computed", "value": "(Event == \"BenefitUpdatedEvent\")" },
    "IsBenefitGrantCreatedEvent":    { "type": "computed", "value": "(Event == \"BenefitGrantCreatedEvent\")" },
    "IsBenefitGrantUpdatedEvent":    { "type": "computed", "value": "(Event == \"BenefitGrantUpdatedEvent\")" },
    "IsBenefitGrantCycledEvent":     { "type": "computed", "value": "(Event == \"BenefitGrantCycledEvent\")" },
    "IsBenefitGrantRevokedEvent":    { "type": "computed", "value": "(Event == \"BenefitGrantRevokedEvent\")" },
    "IsRefundCreatedEvent":          { "type": "computed", "value": "(Event == \"RefundCreatedEvent\")" },
    "IsRefundUpdatedEvent":          { "type": "computed", "value": "(Event == \"RefundUpdatedEvent\")" }
  }
}
