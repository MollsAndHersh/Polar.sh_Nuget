{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/**/*.csproj"],
          "exclude": ["**/obj/**", "**/bin/**"]
        }
      ],
      "dest": "docs/api",
      "globalNamespaceId": "PolarSharp",
      "filter": "docfx-filter.yml",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["index.md", "toc.yml"],
        "src": "docs",
        "dest": "."
      },
      {
        "files": ["**/*.md", "toc.yml"],
        "src": "docs/articles",
        "dest": "articles"
      },
      {
        "files": ["**/*.yml"],
        "src": "docs/api",
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": ["images/**"],
        "src": "docs"
      }
    ],
    "dest": "docs/_site",
    "globalMetadata": {
      "_appName": "PolarSharp",
      "_appTitle": "PolarSharp — .NET SDK for Polar.sh",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitUrlPattern": "auto"
    },
    "template": ["default"],
    "postProcessors": []
  }
}
